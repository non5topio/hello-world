{
    "enabled": "true",
    "increase-coverage": {
      "project-name": "hello-world",
      "target-branches": [
        "master"
      ],
      "test-env-docker-stage": "test",
      "build-test-env-docker-stage-script-path": "tool/build-test-env-docker-stage.sh",
      "test-files-folders": [
        "test"
      ],
      "source-test-file-paths": [
        {
          "source-file-path": "src/HelloWorld.cs",
          "test-file-path": "test/UnitTest1.cs"
        }
      ],
      "test-command": "dotnet test --collect:\\\"XPlat Code Coverage\\\"",
      "coverage-type": "cobertura",
      "code-coverage-report-path": "test/TestResults/579a4942-dd6a-43d8-aaa8-5eaaab22e908/coverage.cobertura.xml",
      "desired-coverage": 90,
      "max-iterations": 1,
      "max-number-of-test-cases": 6
      }
  }

